# Salin file ini ke .env.local dan isi nilainya
# JANGAN commit .env.local ke git

# Better Auth — generate dengan: openssl rand -base64 32
BETTER_AUTH_SECRET=

# URL Vercel deploy Chief (tanpa trailing slash)
BETTER_AUTH_URL=https://sentra-assist-xxx.vercel.app
NEXT_PUBLIC_BETTER_AUTH_URL=https://sentra-assist-xxx.vercel.app

# Turso — dari: turso db show sentra-assist-pilot
DATABASE_URL=libsql://sentra-assist-pilot-xxx.turso.io
DATABASE_AUTH_TOKEN=

# Resend — dari: resend.com/api-keys
RESEND_API_KEY=re_
